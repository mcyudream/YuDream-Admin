# 部署配置，复制为 .env 后按环境修改，不要提交真实 .env

# 镜像
CI_REGISTRY_IMAGE=registry.yudream.online/yudream/yudreamadmin
TAG=latest

# 端口映射
BACKEND_PORT=8080
FRONTEND_PORT=80

# 应用基础地址
APP_BASE_URL=http://localhost:8080
APP_WEB_URL=http://localhost
WEB_LOG_ENABLED=true
WEB_LOG_PREFIX=YuDreamAdmin
SNOWFLAKE_DCI=1
SNOWFLAKE_MI=1
SYSTEM_SEED_MENU_SYNC_MODE=MISSING_ONLY

# MongoDB
MONGO_URI=mongodb://mongo:27017/yudream

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TIMEOUT=2000ms
REDIS_POOL_MAX_ACTIVE=8
REDIS_POOL_MAX_IDLE=8
REDIS_POOL_MIN_IDLE=0

# 邮件
MAIL_HOST=smtp.qq.com
MAIL_PORT=465
MAIL_USERNAME=xxx@qq.com
MAIL_PASSWORD=xxx
MAIL_FROM=xxx@qq.com
MAIL_SSL_ENABLE=true
MAIL_STARTTLS_ENABLE=false

# 缓存
CACHE_KEY_PREFIX=yudream
CACHE_ENABLED=true
CACHE_DEFAULT_NULL_EXPIRE=60
CACHE_L1_ENABLED=false
CACHE_L1_MAX_SIZE=10000
CACHE_L1_EXPIRE=60
CACHE_METRICS_ENABLED=true
CACHE_METRICS_AGGREGATE=true

# 平台能力
PLATFORM_API_DOCS_ENABLED=true
PLATFORM_CMS_ENABLED=true
PLATFORM_FORM_ENABLED=true
PLATFORM_DOCUMENT_TEMPLATE_ENABLED=true
PLATFORM_INTEGRATION_ENABLED=true
PLATFORM_SSE_ENABLED=true
PLATFORM_WEBSOCKET_ENABLED=true
PLATFORM_RABBITMQ_ENABLED=true
PLATFORM_NEO4J_ENABLED=true
PLATFORM_AI_ENABLED=true
PLATFORM_DATAVIZ_ENABLED=true
PLATFORM_SATORI_ENABLED=true
PLATFORM_MESSAGE_RENDER_ENABLED=true
MESSAGE_RENDER_BASE_URL=http://render-server:3000
MESSAGE_RENDER_TOKEN=
MESSAGE_RENDER_TIMEOUT=30s
YUDREAM_SATORI_CREDENTIAL_KEY=
RENDER_CONCURRENCY=2
RENDER_TIMEOUT_MS=30000
PLATFORM_AI_CONNECT_TIMEOUT=30s
PLATFORM_AI_READ_TIMEOUT=10m
PLATFORM_AI_SSE_TIMEOUT=10m

# 插件
YUDREAM_PLATFORM_PLUGIN_ENABLED=true
YUDREAM_PLATFORM_PLUGIN_DIRECTORIES=plugins
YUDREAM_PLATFORM_PLUGIN_UPLOAD_DIRECTORY=plugins

# S3 / MinIO / RustFS
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=rustfsadmin
S3_SECRET_KEY=rustfsadmin
S3_BUCKET=yudream-admin
S3_REGION=us-east-1
S3_PATH_STYLE_ACCESS=true

# 可选中间件 docker-compose.platform.yml
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_PORT=35672
RABBITMQ_MANAGEMENT_PORT=15672
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=yudream123456
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
