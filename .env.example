# 部署配置（复制到生产服务器后按需修改，不要提交到 git）

# GitLab 容器仓库地址
CI_REGISTRY_IMAGE=registry.yudream.online/yudream/yudreamadmin
TAG=latest

# 端口映射
BACKEND_PORT=8080
FRONTEND_PORT=80

# 应用基础地址
APP_BASE_URL=http://localhost:8080
APP_WEB_URL=http://localhost

# 中间件连接（按需填写）
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
MONGO_URI=
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
