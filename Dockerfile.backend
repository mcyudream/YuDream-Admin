# 后端镜像：包含主应用 JAR，插件目录通过挂载注入
FROM swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/library/eclipse-temurin:21-jre-jammy

WORKDIR /app

# 创建插件目录，运行时可挂载宿主机 plugins/ 目录覆盖
RUN mkdir -p /app/plugins

# 复制主应用 JAR（CI 构建产物，spring-boot-maven-plugin 生成的可执行 fat jar）
COPY yudream-bootstrap/target/yudream-bootstrap-*.jar /app/app.jar

# 插件目录挂载点
VOLUME /app/plugins

EXPOSE 8080

# 生产环境默认使用 plugins/ 作为插件扫描目录
ENV YUDREAM_PLATFORM_PLUGIN_DIRECTORIES=/app/plugins

ENTRYPOINT ["java", "-jar", "/app/app.jar"]
