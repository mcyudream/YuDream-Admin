default:
  tags:
    - shared

workflow:
  rules:
    - if: $CI_COMMIT_BRANCH
    - if: $CI_COMMIT_TAG

stages:
  - validate
  - build-frontend
  - package-plugin
  - publish-plugin
  - verify-publish

variables:
  PNPM_IGNORE_PACKAGE_MANAGER_VERSION: "true"
  NEXUS_BASE_URL: "https://nexus.yudream.online"
  NEXUS_MAVEN_PUBLIC_URL: "https://nexus.yudream.online/repository/maven-public/"
  NEXUS_MAVEN_RELEASES_URL: "https://nexus.yudream.online/repository/maven-releases"
  NEXUS_NPM_PUBLIC_URL: "https://nexus.yudream.online/repository/npm-public/"
  NPM_CONFIG_REGISTRY: "https://registry.npmjs.org/"
  COREPACK_NPM_REGISTRY: "https://registry.npmjs.org/"
  YUDREAM_NPM_REGISTRY: "$NEXUS_NPM_PUBLIC_URL"
  MAVEN_OPTS: "-Dmaven.repo.local=$CI_PROJECT_DIR/.m2/repository"
  PACKAGE_MAVEN_REPO: "$CI_PROJECT_DIR/.m2/package-repository"

cache:
  key: "${CI_COMMIT_REF_SLUG}"
  paths:
    - yudream-frontend/.pnpm-store/
    - .m2/repository/
  policy: pull-push

validate:repo:
  stage: validate
  image: alpine:3.20
  script:
    - echo "standalone plugin repository initialized"

validate:independence:
  stage: validate
  image: alpine:3.20
  script:
    - sh ci/verify-plugin-repo-independence.sh

validate:core-maven-registry:
  stage: validate
  image: swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/library/maven:3.9-eclipse-temurin-21
  script:
    - sh ci/verify-core-maven-registry.sh

validate:plugin-maven-boundary:
  stage: validate
  image: alpine:3.20
  script:
    - sh ci/verify-plugin-maven-boundary.sh

validate:core-npm-contracts:
  stage: validate
  image: swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/node:24.15.0-bookworm
  before_script:
    - npm config set registry "$NPM_CONFIG_REGISTRY"
    - corepack enable && corepack prepare pnpm@11.9.0 --activate
    - pnpm config set registry "$NPM_CONFIG_REGISTRY"
  script:
    - sh ci/verify-core-npm-contracts.sh

validate:docs:
  stage: validate
  image: alpine:3.20
  script:
    - sh ci/verify-doc-independence.sh

validate:publish-pipeline:
  stage: validate
  image: alpine:3.20
  script:
    - sh ci/verify-plugin-publish-pipeline.sh

build:frontend:
  image: swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/node:24.15.0-bookworm
  stage: build-frontend
  rules:
    - exists:
        - yudream-frontend/package.json
        - yudream-frontend/packages/plugin-*/package.json
  before_script:
    - npm config set registry "$NPM_CONFIG_REGISTRY"
    - corepack enable && corepack prepare pnpm@11.9.0 --activate
    - pnpm config set registry "$NPM_CONFIG_REGISTRY"
  script:
    - cd yudream-frontend
    - |
      printf '%s\n' \
        "registry=$NPM_CONFIG_REGISTRY" \
        "@yudream:registry=$NEXUS_NPM_PUBLIC_URL" > .npmrc
    - pnpm install --frozen-lockfile
    - pnpm -r --filter=@yudream/plugin-* run build
  artifacts:
    paths:
      - yudream-frontend/packages/plugin-*/dist/

package:plugins:
  image: swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/library/maven:3.9-eclipse-temurin-21
  stage: package-plugin
  script:
    - 'echo "Using Nexus Maven registry: $NEXUS_MAVEN_PUBLIC_URL"'
    - |
      printf '%s\n' \
        '<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"' \
        '          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"' \
        '          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0 https://maven.apache.org/xsd/settings-1.0.0.xsd">' \
        '    <mirrors>' \
        '        <mirror>' \
        '            <id>nexus-public</id>' \
        '            <mirrorOf>*</mirrorOf>' \
        '            <url>${env.NEXUS_MAVEN_PUBLIC_URL}</url>' \
        '        </mirror>' \
        '    </mirrors>' \
        '</settings>' > settings.xml
    - |
      if [ -z "$NEXUS_MAVEN_PUBLIC_URL" ]; then
        echo "NEXUS_MAVEN_PUBLIC_URL is required"
        exit 1
      fi
    - rm -rf "$PACKAGE_MAVEN_REPO"
    - mkdir -p "$PACKAGE_MAVEN_REPO"
    - mvn -s settings.xml "-Dmaven.repo.local=$PACKAGE_MAVEN_REPO" clean package -DskipTests -B -e
    - sh ci/verify-plugin-jar-assets.sh
    - rm -rf dist/plugins
    - mkdir -p dist/plugins
    - |
      . ./ci/lib/plugin-jar-selection.sh
      copy_final_plugin_jars "$PWD" "$PWD/dist/plugins"
    - ls -R dist/plugins
  artifacts:
    paths:
      - dist/plugins/*.jar
    expire_in: 1 week

publish:plugin-jars:
  image: swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/library/maven:3.9-eclipse-temurin-21
  stage: publish-plugin
  dependencies:
    - package:plugins
  script:
    - sh ci/publish-plugin-jars.sh
  rules:
    - if: $CI_COMMIT_TAG =~ /^v/

verify:published-plugin-jars:
  image: swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/library/maven:3.9-eclipse-temurin-21
  stage: verify-publish
  dependencies:
    - package:plugins
  script:
    - sh ci/verify-published-plugin-jars.sh
  rules:
    - if: $CI_COMMIT_TAG =~ /^v/
