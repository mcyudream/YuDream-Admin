default:
  tags:
    - shared

workflow:
  rules:
    - if: $CI_COMMIT_BRANCH
    - if: $CI_COMMIT_TAG

stages:
  - validate
  - build-frontend
  - package-plugin
  - publish-plugin
  - verify-publish

variables:
  PNPM_IGNORE_PACKAGE_MANAGER_VERSION: "true"
  NPM_CONFIG_REGISTRY: "https://registry.npmjs.org/"
  COREPACK_NPM_REGISTRY: "https://registry.npmjs.org/"
  YUDREAM_NPM_REGISTRY: "https://registry.npmjs.org/"
  MAVEN_OPTS: "-Dmaven.repo.local=$CI_PROJECT_DIR/.m2/repository"
  PACKAGE_MAVEN_REPO: "$CI_PROJECT_DIR/.m2/package-repository"
  CORE_MAVEN_REGISTRY: "https://gitlab.example.com/api/v4/projects/CORE_PROJECT_ID/packages/maven"
  CORE_NPM_REGISTRY: ""
  CORE_PACKAGE_USER: "gitlab-ci-token"
  CORE_PACKAGE_TOKEN: ""

cache:
  key: "${CI_COMMIT_REF_SLUG}"
  paths:
    - yudream-frontend/.pnpm-store/
    - .m2/repository/
  policy: pull-push

validate:repo:
  stage: validate
  image: alpine:3.20
  script:
    - echo "standalone plugin repository initialized"

validate:independence:
  stage: validate
  image: alpine:3.20
  script:
    - sh ci/verify-plugin-repo-independence.sh

validate:core-maven-registry:
  stage: validate
  image: swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/library/maven:3.9-eclipse-temurin-21
  script:
    - sh ci/verify-core-maven-registry.sh

validate:plugin-maven-boundary:
  stage: validate
  image: alpine:3.20
  script:
    - sh ci/verify-plugin-maven-boundary.sh

validate:core-npm-contracts:
  stage: validate
  image: swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/node:24.15.0-bookworm
  before_script:
    - npm config set registry "$NPM_CONFIG_REGISTRY"
    - corepack enable && corepack prepare pnpm@11.9.0 --activate
    - pnpm config set registry "$NPM_CONFIG_REGISTRY"
  script:
    - sh ci/verify-core-npm-contracts.sh

validate:docs:
  stage: validate
  image: alpine:3.20
  script:
    - sh ci/verify-doc-independence.sh

validate:publish-pipeline:
  stage: validate
  image: alpine:3.20
  script:
    - sh ci/verify-plugin-publish-pipeline.sh

build:frontend:
  image: swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/node:24.15.0-bookworm
  stage: build-frontend
  rules:
    - exists:
        - yudream-frontend/package.json
        - yudream-frontend/packages/plugin-*/package.json
  before_script:
    - npm config set registry "$NPM_CONFIG_REGISTRY"
    - corepack enable && corepack prepare pnpm@11.9.0 --activate
    - pnpm config set registry "$NPM_CONFIG_REGISTRY"
  script:
    - cd yudream-frontend
    - |
      if [ -n "$CORE_NPM_REGISTRY" ]; then
        PACKAGE_TOKEN="${CORE_PACKAGE_TOKEN:-$CI_JOB_TOKEN}"
        REGISTRY_HOST=$(echo "$CORE_NPM_REGISTRY" | sed -E 's#^https?://##')
        cat > .npmrc <<EOF
        @yudream:registry=$CORE_NPM_REGISTRY
        //$REGISTRY_HOST:_authToken=$PACKAGE_TOKEN
        always-auth=true
        EOF
      else
        cat > .npmrc <<EOF
        @yudream:registry=$YUDREAM_NPM_REGISTRY
        EOF
      fi
    - pnpm install --frozen-lockfile
    - pnpm -r --filter=@yudream/plugin-* run build
  artifacts:
    paths:
      - yudream-frontend/packages/plugin-*/dist/

package:plugins:
  image: swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/library/maven:3.9-eclipse-temurin-21
  stage: package-plugin
  script:
    - echo "Using core Maven registry: $CORE_MAVEN_REGISTRY"
    - |
      cat > settings.xml <<EOF
      <settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"
                xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0 https://maven.apache.org/xsd/settings-1.0.0.xsd">
          <servers>
              <server>
                  <id>gitlab-maven</id>
                  <username>${CORE_PACKAGE_USER}</username>
                  <password>${CORE_PACKAGE_TOKEN:-$CI_JOB_TOKEN}</password>
              </server>
          </servers>
          <profiles>
              <profile>
                  <id>gitlab-private</id>
                  <repositories>
                      <repository>
                          <id>gitlab-maven</id>
                          <url>${CORE_MAVEN_REGISTRY}</url>
                      </repository>
                  </repositories>
              </profile>
          </profiles>
          <activeProfiles>
              <activeProfile>gitlab-private</activeProfile>
          </activeProfiles>
      </settings>
      EOF
    - |
      if [ -z "$CORE_MAVEN_REGISTRY" ]; then
        echo "CORE_MAVEN_REGISTRY is required for plugin repo package job"
        exit 1
      fi
    - rm -rf "$PACKAGE_MAVEN_REPO"
    - mkdir -p "$PACKAGE_MAVEN_REPO"
    - mvn -s settings.xml "-Dmaven.repo.local=$PACKAGE_MAVEN_REPO" clean package -DskipTests -B -e
    - sh ci/verify-plugin-jar-assets.sh
  artifacts:
    paths:
      - yudream-plugins/*/target/*.jar

publish:plugin-jars:
  image: alpine:3.20
  stage: publish-plugin
  dependencies:
    - package:plugins
  before_script:
    - apk add --no-cache curl
  script:
    - sh ci/publish-plugin-jars.sh
  rules:
    - if: $CI_COMMIT_TAG =~ /^v/

verify:published-plugin-jars:
  image: alpine:3.20
  stage: verify-publish
  dependencies:
    - package:plugins
  before_script:
    - apk add --no-cache curl
  script:
    - sh ci/verify-published-plugin-jars.sh
  rules:
    - if: $CI_COMMIT_TAG =~ /^v/
