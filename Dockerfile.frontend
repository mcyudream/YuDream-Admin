# 前端镜像：用 nginx 托管主体前端 dist
FROM swr.cn-north-4.myhuaweicloud.com/ddn-k8s/docker.io/nginx:alpine3.22-slim

# 复制主体前端构建产物
COPY yudream-frontend/apps/core-arco-design-vue/dist /usr/share/nginx/html

# 自定义 nginx 配置，支持 Vue Router history 模式
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
